{
  "id": "cloudflare",
  "name": "Cloudflare",
  "description": "Manage Cloudflare Workers, KV, DNS, and more via Cloudflare's remote MCP servers",
  "version": "1.0.0",
  "category": "devops",
  "icon": "cloud",
  "website": "https://cloudflare.com",
  "docs": "https://github.com/cloudflare/mcp-server-cloudflare",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "CLOUDFLARE_API_TOKEN",
        "label": "Cloudflare API Token",
        "description": "API token with appropriate permissions for Workers, DNS, etc.",
        "required": true,
        "sensitive": true,
        "placeholder": "..."
      },
      {
        "key": "CLOUDFLARE_ACCOUNT_ID",
        "label": "Account ID",
        "description": "Cloudflare account ID from the dashboard",
        "required": true,
        "sensitive": false,
        "placeholder": "..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "servers": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "bindings",
            "observability",
            "docs",
            "builds",
            "radar",
            "containers",
            "browser",
            "logpush",
            "ai-gateway",
            "autorag",
            "auditlogs",
            "dns-analytics",
            "dex",
            "casb",
            "graphql"
          ]
        },
        "default": ["bindings", "observability"],
        "description": "Which Cloudflare MCP sub-servers to enable"
      }
    }
  },
  "capabilities": ["tool", "action"],
  "tags": ["devops", "cdn", "dns", "workers", "serverless", "mcp"],
  "popularity": 80
}
