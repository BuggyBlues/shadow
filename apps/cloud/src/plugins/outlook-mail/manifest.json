{
  "id": "outlook-mail",
  "name": "Outlook Mail",
  "description": "Connect agents to Microsoft 365 mail",
  "version": "1.0.0",
  "category": "email",
  "icon": "mail",
  "website": "https://outlook.com",
  "auth": {
    "type": "oauth2",
    "fields": [
      {
        "key": "OUTLOOK_CLIENT_ID",
        "label": "Client ID",
        "required": true,
        "sensitive": true
      },
      {
        "key": "OUTLOOK_CLIENT_SECRET",
        "label": "Client Secret",
        "required": true,
        "sensitive": true
      },
      {
        "key": "OUTLOOK_TENANT_ID",
        "label": "Tenant ID",
        "required": true,
        "sensitive": true
      }
    ],
    "oauth": {
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "scopes": ["Mail.ReadWrite", "Mail.Send"]
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "folders": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": ["Inbox"]
      }
    }
  },
  "capabilities": ["channel", "tool"],
  "tags": ["email", "microsoft", "office365"],
  "popularity": 72
}
