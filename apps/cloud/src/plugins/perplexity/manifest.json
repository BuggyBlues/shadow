{
  "id": "perplexity",
  "name": "Perplexity",
  "description": "Connect agents to Perplexity Sonar models for search-augmented AI answers",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "search",
  "website": "https://perplexity.ai",
  "docs": "https://docs.perplexity.ai",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "PERPLEXITY_API_KEY",
        "label": "API Key",
        "description": "Perplexity API key (OpenAI-compatible Bearer token)",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "sonar-pro",
        "description": "Default Sonar model (sonar, sonar-pro, sonar-reasoning-pro)"
      },
      "searchDomainFilter": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Limit search to specific domains"
      },
      "returnCitations": {
        "type": "boolean",
        "default": true,
        "description": "Include source citations in responses"
      }
    }
  },
  "capabilities": ["auth-provider", "tool"],
  "tags": ["ai", "search", "llm", "sonar", "openai-compatible"],
  "popularity": 78
}
