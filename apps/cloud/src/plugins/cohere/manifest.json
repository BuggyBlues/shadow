{
  "id": "cohere",
  "name": "Cohere",
  "description": "Connect agents to Cohere Command, Embed, and Rerank models",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "zap",
  "website": "https://cohere.com",
  "docs": "https://docs.cohere.com/reference/about",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "COHERE_API_KEY",
        "label": "API Key",
        "description": "Cohere API key (Bearer token)",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "command-a-03-2025",
        "description": "Default Command model for chat"
      },
      "embedModel": {
        "type": "string",
        "description": "Embedding model (e.g. embed-v4.0)"
      },
      "rerankModel": {
        "type": "string",
        "description": "Rerank model (e.g. rerank-v3.5)"
      }
    }
  },
  "capabilities": ["auth-provider"],
  "tags": ["ai", "llm", "nlp", "embeddings", "rerank"],
  "popularity": 60
}
