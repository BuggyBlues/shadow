{
  "id": "fireflies",
  "name": "Fireflies.ai",
  "description": "AI meeting transcription and note-taking — query transcripts, summaries, and action items via Fireflies GraphQL API",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "mic",
  "website": "https://fireflies.ai",
  "docs": "https://docs.fireflies.ai/graphql-api/overview",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "FIREFLIES_API_KEY",
        "label": "Fireflies API Key",
        "description": "API key from https://app.fireflies.ai/integrations/custom/fireflies (requires Business or Enterprise plan)",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "https://api.fireflies.ai/graphql",
        "description": "Fireflies GraphQL API endpoint"
      },
      "language": {
        "type": "string",
        "default": "en",
        "description": "Preferred transcript language"
      }
    }
  },
  "capabilities": ["tool", "data-source"],
  "tags": ["meetings", "transcription", "ai", "notes"],
  "popularity": 55
}
