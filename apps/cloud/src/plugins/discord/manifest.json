{
  "id": "discord",
  "name": "Discord",
  "description": "Connect agents to Discord servers for messaging",
  "version": "1.0.0",
  "category": "communication",
  "icon": "message-square",
  "website": "https://discord.com",
  "docs": "https://discord.com/developers/docs",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "DISCORD_BOT_TOKEN",
        "label": "Bot Token",
        "required": true,
        "sensitive": true
      },
      {
        "key": "DISCORD_APPLICATION_ID",
        "label": "Application ID",
        "required": true,
        "sensitive": false
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "guildId": {
        "type": "string",
        "description": "Discord server (guild) ID"
      },
      "channels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Channel IDs to listen on"
      },
      "mentionOnly": {
        "type": "boolean",
        "default": true
      }
    }
  },
  "capabilities": ["channel", "notification"],
  "tags": ["communication", "messaging", "gaming"],
  "popularity": 88
}
