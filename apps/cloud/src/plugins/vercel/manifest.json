{
  "id": "vercel",
  "name": "Vercel",
  "description": "Deploy, manage, and monitor projects on Vercel via the Vercel MCP server",
  "version": "1.0.0",
  "category": "devops",
  "icon": "triangle",
  "website": "https://vercel.com",
  "docs": "https://vercel.com/docs/rest-api",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "VERCEL_TOKEN",
        "label": "Vercel API Token",
        "description": "API token from Vercel dashboard (Settings → Tokens)",
        "required": true,
        "sensitive": true,
        "placeholder": "..."
      },
      {
        "key": "VERCEL_TEAM_ID",
        "label": "Team ID",
        "description": "Vercel team ID for team-scoped operations (optional for personal accounts)",
        "required": false,
        "sensitive": false,
        "placeholder": "team_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "projects": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Vercel project names to manage"
      }
    }
  },
  "capabilities": ["tool", "action"],
  "tags": ["devops", "deployment", "hosting", "serverless", "mcp"],
  "popularity": 82
}
