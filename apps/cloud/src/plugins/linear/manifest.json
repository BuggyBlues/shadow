{
  "id": "linear",
  "name": "Linear",
  "description": "Issue tracking and project management with Linear via MCP server — manage issues, projects, teams, cycles, and labels",
  "version": "1.0.0",
  "category": "project-management",
  "icon": "target",
  "website": "https://linear.app",
  "docs": "https://www.npmjs.com/package/linear-mcp-server",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "LINEAR_API_KEY",
        "label": "API Key",
        "description": "Linear personal API key from Settings → API",
        "required": true,
        "sensitive": true,
        "placeholder": "lin_api_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "teamId": {
        "type": "string",
        "description": "Default team ID to scope operations"
      },
      "defaultProject": {
        "type": "string",
        "description": "Default project slug or ID"
      }
    }
  },
  "capabilities": ["tool", "data-source", "webhook", "action"],
  "tags": ["project-management", "issues", "engineering", "mcp"],
  "popularity": 82
}
