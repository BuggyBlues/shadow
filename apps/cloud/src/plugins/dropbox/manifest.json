{
  "id": "dropbox",
  "name": "Dropbox",
  "description": "Access, manage, upload, and organize files on Dropbox via MCP server with full CRUD operations",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "box",
  "website": "https://dropbox.com",
  "docs": "https://www.npmjs.com/package/@microagents/mcp-server-dropbox",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "DROPBOX_ACCESS_TOKEN",
        "label": "Dropbox Access Token",
        "description": "OAuth2 access token from https://www.dropbox.com/developers/apps",
        "required": true,
        "sensitive": true,
        "placeholder": "sl...."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "rootPath": {
        "type": "string",
        "default": "/",
        "description": "Root path to restrict Dropbox access to"
      }
    }
  },
  "capabilities": ["data-source", "tool"],
  "tags": ["productivity", "storage", "files", "mcp"],
  "popularity": 60
}
