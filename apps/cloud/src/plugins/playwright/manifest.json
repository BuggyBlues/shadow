{
  "id": "playwright",
  "name": "Playwright",
  "description": "Browser automation via the official Playwright MCP server from Microsoft. Enables web interaction through structured accessibility snapshots.",
  "version": "1.0.0",
  "category": "devops",
  "icon": "globe",
  "website": "https://playwright.dev",
  "docs": "https://github.com/microsoft/playwright-mcp",
  "auth": {
    "type": "none",
    "fields": []
  },
  "config": {
    "type": "object",
    "properties": {
      "browser": {
        "type": "string",
        "enum": ["chrome", "firefox", "webkit", "msedge"],
        "default": "chrome",
        "description": "Browser or channel to use"
      },
      "headless": {
        "type": "boolean",
        "default": true,
        "description": "Run browser in headless mode (headed by default in non-K8s)"
      },
      "caps": {
        "type": "string",
        "description": "Additional capabilities: vision, pdf, devtools, network, storage, testing",
        "default": ""
      },
      "viewport": {
        "type": "string",
        "description": "Browser viewport size (e.g. '1280x720')"
      },
      "isolated": {
        "type": "boolean",
        "default": false,
        "description": "Keep browser profile in memory, do not save to disk"
      }
    }
  },
  "capabilities": ["tool"],
  "tags": ["browser", "automation", "testing", "web-scraping", "mcp"],
  "popularity": 75
}
