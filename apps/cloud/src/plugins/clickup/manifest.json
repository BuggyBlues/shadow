{
  "id": "clickup",
  "name": "ClickUp",
  "description": "Project management and productivity with ClickUp via MCP server — manage tasks, documents, chats, spaces, and time tracking",
  "version": "1.0.0",
  "category": "project-management",
  "icon": "check-circle",
  "website": "https://clickup.com",
  "docs": "https://www.npmjs.com/package/@taazkareem/clickup-mcp-server",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "CLICKUP_API_TOKEN",
        "label": "API Token",
        "description": "ClickUp personal API token from Settings → Apps",
        "required": true,
        "sensitive": true,
        "placeholder": "pk_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "workspaceId": {
        "type": "string",
        "description": "Default ClickUp workspace (team) ID"
      }
    }
  },
  "capabilities": ["tool", "data-source", "action"],
  "tags": ["project-management", "tasks", "productivity", "time-tracking", "mcp"],
  "popularity": 68
}
