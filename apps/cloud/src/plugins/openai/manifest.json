{
  "id": "openai",
  "name": "OpenAI",
  "description": "Connect agents to OpenAI API for GPT, o-series reasoning, and embedding models",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "brain",
  "website": "https://openai.com",
  "docs": "https://developers.openai.com/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "OPENAI_API_KEY",
        "label": "API Key",
        "description": "OpenAI API key (Bearer token)",
        "required": true,
        "sensitive": true,
        "placeholder": "sk-..."
      },
      {
        "key": "OPENAI_ORG_ID",
        "label": "Organization ID",
        "description": "Optional organization ID for billing attribution",
        "required": false,
        "sensitive": false
      },
      {
        "key": "OPENAI_PROJECT_ID",
        "label": "Project ID",
        "description": "Optional project ID for resource scoping",
        "required": false,
        "sensitive": false
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "gpt-4o",
        "description": "Default model for completions (e.g. gpt-4o, o4-mini)"
      },
      "baseUrl": {
        "type": "string",
        "description": "Custom base URL for Azure OpenAI or proxies"
      },
      "models": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Allowed model IDs"
      }
    }
  },
  "capabilities": ["auth-provider", "tool"],
  "tags": ["ai", "llm", "gpt", "o-series", "embeddings"],
  "popularity": 99
}
