{
  "id": "grok",
  "name": "Grok",
  "description": "Connect agents to xAI Grok models via OpenAI-compatible API",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "bot",
  "website": "https://x.ai",
  "docs": "https://docs.x.ai/developers/quickstart",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "XAI_API_KEY",
        "label": "API Key",
        "description": "xAI API key from console.x.ai",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "grok-3-fast",
        "description": "Default Grok model (grok-3-fast, grok-3, grok-3-mini, grok-2-vision)"
      },
      "enableWebSearch": {
        "type": "boolean",
        "default": false,
        "description": "Enable built-in web search tool"
      },
      "enableXSearch": {
        "type": "boolean",
        "default": false,
        "description": "Enable X (Twitter) search tool"
      }
    }
  },
  "capabilities": ["auth-provider", "tool"],
  "tags": ["ai", "llm", "xai", "grok", "openai-compatible"],
  "popularity": 55
}
