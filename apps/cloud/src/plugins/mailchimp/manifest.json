{
  "id": "mailchimp",
  "name": "Mailchimp",
  "description": "Email marketing campaigns, automations, lists, templates, and analytics via Mailchimp MCP server",
  "version": "1.0.0",
  "category": "email",
  "icon": "mail",
  "website": "https://mailchimp.com",
  "docs": "https://mailchimp.com/developer/marketing/api",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "MAILCHIMP_API_KEY",
        "label": "Mailchimp API Key",
        "description": "API key from Account > Extras > API Keys. Format: key-dc (e.g. abc123-us21)",
        "required": true,
        "sensitive": true,
        "placeholder": "...-us21"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {}
  },
  "capabilities": ["tool", "data-source", "action"],
  "tags": ["email", "marketing", "automation", "campaigns", "mcp"],
  "popularity": 75
}
