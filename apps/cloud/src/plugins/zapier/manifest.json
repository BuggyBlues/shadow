{
  "id": "zapier",
  "name": "Zapier",
  "description": "Workflow automation and app integration via the official Zapier SDK MCP server — run actions, manage connections, tables, and apps",
  "version": "1.0.0",
  "category": "automation",
  "icon": "zap",
  "website": "https://zapier.com",
  "docs": "https://www.npmjs.com/package/@zapier/zapier-sdk-mcp",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "ZAPIER_CLIENT_ID",
        "label": "Client ID",
        "description": "Zapier SDK client ID for OAuth client credentials flow",
        "required": true,
        "sensitive": true,
        "placeholder": "cli_..."
      },
      {
        "key": "ZAPIER_CLIENT_SECRET",
        "label": "Client Secret",
        "description": "Zapier SDK client secret",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "Enable debug logging for the Zapier MCP server"
      }
    }
  },
  "capabilities": ["tool", "action", "webhook"],
  "tags": ["automation", "workflow", "integration", "mcp"],
  "popularity": 85
}
