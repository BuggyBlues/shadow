{
  "id": "anthropic",
  "name": "Anthropic",
  "description": "Connect agents to Anthropic Claude models via the Messages API",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "brain",
  "website": "https://anthropic.com",
  "docs": "https://platform.claude.com/docs/en/api/getting-started",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "ANTHROPIC_API_KEY",
        "label": "API Key",
        "description": "Anthropic API key (x-api-key header)",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "claude-sonnet-4-20250514",
        "description": "Default Claude model"
      },
      "apiVersion": {
        "type": "string",
        "default": "2023-06-01",
        "description": "Anthropic API version (anthropic-version header)"
      },
      "maxTokens": {
        "type": "number",
        "default": 4096,
        "description": "Default max tokens for responses"
      }
    }
  },
  "capabilities": ["auth-provider"],
  "tags": ["ai", "llm", "claude", "messages-api"],
  "popularity": 96
}
