{
  "id": "tldv",
  "name": "tl;dv",
  "description": "Access meeting transcripts, highlights, and metadata from Google Meet, Zoom, and Microsoft Teams via tl;dv MCP server",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "video",
  "website": "https://tldv.io",
  "docs": "https://www.npmjs.com/package/tldv-mcp",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "TLDV_API_KEY",
        "label": "tl;dv API Key",
        "description": "API key from https://tldv.io/app/settings/personal-settings/api-keys (requires Business or Enterprise plan)",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "enableAutoRecording": {
        "type": "boolean",
        "default": false,
        "description": "Enable automatic recording of meetings"
      }
    }
  },
  "capabilities": ["tool", "data-source"],
  "tags": ["meetings", "recording", "transcription", "ai", "mcp"],
  "popularity": 48
}
