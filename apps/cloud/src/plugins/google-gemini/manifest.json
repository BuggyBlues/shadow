{
  "id": "google-gemini",
  "name": "Google Gemini",
  "description": "Connect agents to Google Gemini AI models via AI Studio or Vertex AI",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "sparkles",
  "website": "https://ai.google.dev",
  "docs": "https://ai.google.dev/gemini-api/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "GOOGLE_AI_API_KEY",
        "label": "API Key",
        "description": "Google AI Studio API key (get one at aistudio.google.com/apikey)",
        "required": true,
        "sensitive": true
      },
      {
        "key": "GOOGLE_CLOUD_PROJECT",
        "label": "Cloud Project ID",
        "description": "Required for Vertex AI; Google Cloud project ID",
        "required": false,
        "sensitive": false
      },
      {
        "key": "GOOGLE_CLOUD_LOCATION",
        "label": "Cloud Region",
        "description": "Vertex AI region (e.g. us-central1)",
        "required": false,
        "sensitive": false,
        "placeholder": "us-central1"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "gemini-2.0-flash",
        "description": "Default Gemini model"
      },
      "useVertexAI": {
        "type": "boolean",
        "default": false,
        "description": "Use Vertex AI instead of AI Studio"
      }
    }
  },
  "capabilities": ["auth-provider"],
  "tags": ["ai", "llm", "gemini", "google", "vertex-ai"],
  "popularity": 90
}
