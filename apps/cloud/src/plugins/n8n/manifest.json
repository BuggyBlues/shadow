{
  "id": "n8n",
  "name": "n8n",
  "description": "Self-hosted workflow automation with n8n — manage workflows, executions, and credentials via MCP server",
  "version": "1.0.0",
  "category": "automation",
  "icon": "git-branch",
  "website": "https://n8n.io",
  "docs": "https://www.npmjs.com/package/@leonardsellem/n8n-mcp-server",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "N8N_API_KEY",
        "label": "API Key",
        "description": "n8n API key from Settings → API",
        "required": true,
        "sensitive": true
      },
      {
        "key": "N8N_BASE_URL",
        "label": "Base URL",
        "description": "n8n instance URL (e.g., https://n8n.example.com)",
        "required": true,
        "sensitive": false,
        "placeholder": "https://n8n.example.com"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "workflows": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Specific workflow IDs to expose (all if empty)"
      }
    }
  },
  "capabilities": ["tool", "webhook", "action"],
  "tags": ["automation", "workflow", "self-hosted", "mcp"],
  "popularity": 70
}
