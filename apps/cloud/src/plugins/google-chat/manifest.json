{
  "id": "google-chat",
  "name": "Google Chat",
  "description": "Connect agents to Google Chat spaces",
  "version": "1.0.0",
  "category": "communication",
  "icon": "message-square",
  "website": "https://chat.google.com",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "GOOGLE_CHAT_SERVICE_ACCOUNT_KEY",
        "label": "Service Account Key",
        "required": true,
        "sensitive": true,
        "description": "JSON service account key"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "spaces": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Google Chat space IDs"
      }
    }
  },
  "capabilities": ["channel"],
  "tags": ["communication", "google", "workspace"],
  "popularity": 65
}
