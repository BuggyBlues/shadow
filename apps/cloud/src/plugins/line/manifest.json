{
  "id": "line",
  "name": "LINE",
  "description": "Connect agents to LINE Messaging API",
  "version": "1.0.0",
  "category": "communication",
  "icon": "message-circle",
  "website": "https://line.me",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "LINE_CHANNEL_ACCESS_TOKEN",
        "label": "Channel Access Token",
        "required": true,
        "sensitive": true
      },
      {
        "key": "LINE_CHANNEL_SECRET",
        "label": "Channel Secret",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "replyMode": {
        "type": "string",
        "enum": ["reply", "push"],
        "default": "reply"
      }
    }
  },
  "capabilities": ["channel", "webhook"],
  "tags": ["communication", "messaging", "japan"],
  "popularity": 70
}
