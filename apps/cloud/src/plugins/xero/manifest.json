{
  "id": "xero",
  "name": "Xero",
  "description": "Connect agents to Xero for accounting, invoicing, contacts, payroll, and financial reporting via the official Xero MCP server",
  "version": "1.0.0",
  "category": "finance",
  "icon": "calculator",
  "website": "https://xero.com",
  "docs": "https://developer.xero.com/documentation/api/",
  "auth": {
    "type": "oauth2",
    "fields": [
      {
        "key": "XERO_CLIENT_ID",
        "label": "Xero Client ID",
        "description": "OAuth2 client ID from your Xero Custom Connection app",
        "required": true,
        "sensitive": true
      },
      {
        "key": "XERO_CLIENT_SECRET",
        "label": "Xero Client Secret",
        "description": "OAuth2 client secret from your Xero Custom Connection app",
        "required": true,
        "sensitive": true
      }
    ],
    "oauth": {
      "authorizationUrl": "https://login.xero.com/identity/connect/authorize",
      "tokenUrl": "https://identity.xero.com/connect/token",
      "scopes": [
        "openid",
        "profile",
        "email",
        "accounting.transactions",
        "accounting.contacts",
        "accounting.settings",
        "accounting.reports.read"
      ]
    }
  },
  "config": {
    "type": "object",
    "properties": {}
  },
  "capabilities": ["tool", "data-source", "action"],
  "tags": ["finance", "accounting", "invoicing", "payroll", "mcp"],
  "popularity": 55
}
