{
  "id": "heygen",
  "name": "HeyGen",
  "description": "AI video generation with customizable avatars, voices, templates, and video translation via HeyGen MCP server",
  "version": "1.0.0",
  "category": "media",
  "icon": "video",
  "website": "https://heygen.com",
  "docs": "https://docs.heygen.com",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "HEYGEN_API_KEY",
        "label": "API Key",
        "description": "HeyGen API key from https://app.heygen.com/settings",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "avatarId": {
        "type": "string",
        "description": "Default avatar ID for video generation"
      },
      "templateId": {
        "type": "string",
        "description": "Default template ID for template-based generation"
      },
      "defaultVoiceLanguage": {
        "type": "string",
        "default": "en",
        "description": "Default language filter for voice listing"
      }
    }
  },
  "capabilities": ["tool", "action"],
  "tags": ["media", "video", "avatar", "ai", "tts", "translation"],
  "popularity": 65
}
