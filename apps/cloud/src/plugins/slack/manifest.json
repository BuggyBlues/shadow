{
  "id": "slack",
  "name": "Slack",
  "description": "Connect agents to Slack workspaces for messaging and notifications",
  "version": "1.0.0",
  "category": "communication",
  "icon": "slack",
  "website": "https://slack.com",
  "docs": "https://docs.slack.dev",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "SLACK_BOT_TOKEN",
        "label": "Bot Token",
        "description": "xoxb-... token from your Slack app",
        "required": true,
        "sensitive": true,
        "placeholder": "xoxb-..."
      },
      {
        "key": "SLACK_SIGNING_SECRET",
        "label": "Signing Secret",
        "description": "Used for webhook request verification",
        "required": false,
        "sensitive": true
      },
      {
        "key": "SLACK_APP_TOKEN",
        "label": "App Token",
        "description": "xapp-... token for Socket Mode",
        "required": false,
        "sensitive": true,
        "placeholder": "xapp-..."
      }
    ],
    "oauth": {
      "authorizationUrl": "https://slack.com/oauth/v2/authorize",
      "tokenUrl": "https://slack.com/api/oauth.v2.access",
      "scopes": [
        "chat:write",
        "channels:read",
        "channels:history",
        "users:read",
        "app_mentions:read"
      ]
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "channels": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Slack channel IDs to listen on"
      },
      "defaultChannel": {
        "type": "string",
        "description": "Default channel for outbound messages"
      },
      "mentionOnly": {
        "type": "boolean",
        "default": true,
        "description": "Only respond when @mentioned"
      },
      "socketMode": {
        "type": "boolean",
        "default": false,
        "description": "Use Socket Mode instead of webhooks"
      }
    }
  },
  "capabilities": ["channel", "notification", "webhook"],
  "tags": ["communication", "messaging", "team", "chat"],
  "popularity": 95
}
