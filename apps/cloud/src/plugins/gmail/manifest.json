{
  "id": "gmail",
  "name": "Gmail",
  "description": "Connect agents to Gmail for email operations",
  "version": "1.0.0",
  "category": "email",
  "icon": "mail",
  "website": "https://gmail.com",
  "auth": {
    "type": "oauth2",
    "fields": [
      {
        "key": "GMAIL_CLIENT_ID",
        "label": "Client ID",
        "required": true,
        "sensitive": true
      },
      {
        "key": "GMAIL_CLIENT_SECRET",
        "label": "Client Secret",
        "required": true,
        "sensitive": true
      },
      {
        "key": "GMAIL_REFRESH_TOKEN",
        "label": "Refresh Token",
        "required": true,
        "sensitive": true
      }
    ],
    "oauth": {
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "scopes": ["https://www.googleapis.com/auth/gmail.modify"]
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "labels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Gmail labels to monitor"
      },
      "pollInterval": {
        "type": "number",
        "default": 60
      }
    }
  },
  "capabilities": ["channel", "tool"],
  "tags": ["email", "google", "communication"],
  "popularity": 80
}
