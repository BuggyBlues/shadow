{
  "id": "ahrefs",
  "name": "Ahrefs",
  "description": "SEO analytics, backlink analysis, and keyword research via the official Ahrefs MCP server",
  "version": "1.0.0",
  "category": "analytics",
  "icon": "trending-up",
  "website": "https://ahrefs.com",
  "docs": "https://docs.ahrefs.com/docs/api",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "AHREFS_API_KEY",
        "label": "Ahrefs API Key",
        "description": "API key from Ahrefs (see https://docs.ahrefs.com/docs/api/reference/api-keys-creation-and-management)",
        "required": true,
        "sensitive": true,
        "placeholder": "ahrefs_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "targets": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Default target domains/URLs for SEO analysis"
      }
    }
  },
  "capabilities": ["data-source", "tool"],
  "tags": ["analytics", "seo", "marketing", "backlinks", "mcp"],
  "popularity": 60
}
