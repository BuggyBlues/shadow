{
  "id": "jotform",
  "name": "Jotform",
  "description": "Online form builder and data collection with Jotform — access forms, submissions, reports, and webhooks",
  "version": "1.0.0",
  "category": "automation",
  "icon": "clipboard",
  "website": "https://www.jotform.com",
  "docs": "https://api.jotform.com/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "JOTFORM_API_KEY",
        "label": "API Key",
        "description": "Jotform API key from Settings → API",
        "required": true,
        "sensitive": true,
        "placeholder": "..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "formIds": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Specific form IDs to expose (all if empty)"
      },
      "euRegion": {
        "type": "boolean",
        "default": false,
        "description": "Use EU API endpoint (eu-api.jotform.com)"
      }
    }
  },
  "capabilities": ["webhook", "data-source"],
  "tags": ["forms", "data-collection", "surveys", "automation"],
  "popularity": 50
}
