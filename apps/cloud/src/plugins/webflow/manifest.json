        "required": true,
        "sensitive": true
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "siteId": {
        "type": "string",
        "description": "Default Webflow site ID to operate on"
      }
    }
  },
  "capabilities": ["tool", "action", "data-source"],
  "tags": ["web", "cms", "design", "website", "webflow"],
