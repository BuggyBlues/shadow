{
  "id": "polygon-io",
  "name": "Polygon.io",
  "description": "Real-time and historical financial market data including stocks, options, forex, and crypto via the Polygon.io REST API",
  "version": "1.0.0",
  "category": "finance",
  "icon": "trending-up",
  "website": "https://polygon.io",
  "docs": "https://polygon.io/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "POLYGON_API_KEY",
        "label": "Polygon.io API Key",
        "description": "API key from your Polygon.io account (see https://polygon.io/dashboard/keys)",
        "required": true,
        "sensitive": true,
        "placeholder": "pk_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "https://api.polygon.io",
        "description": "Polygon.io API base URL"
      },
      "tickers": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Default stock tickers to track (e.g. AAPL, GOOGL)"
      }
    }
  },
  "capabilities": ["data-source", "tool"],
  "tags": ["finance", "markets", "stocks", "options", "forex", "crypto"],
  "popularity": 55
}
