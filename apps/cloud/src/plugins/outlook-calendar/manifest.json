{
  "id": "outlook-calendar",
  "name": "Outlook Calendar",
  "description": "Manage events, scheduling, contacts, and tasks with Microsoft Outlook via Microsoft Graph API MCP server",
  "version": "1.0.0",
  "category": "calendar",
  "icon": "calendar",
  "website": "https://outlook.com",
  "docs": "https://www.npmjs.com/package/outlook-mcp",
  "auth": {
    "type": "oauth2",
    "fields": [
      {
        "key": "MS_CLIENT_ID",
        "label": "Azure App Client ID",
        "description": "Application (client) ID from Azure Portal App Registration",
        "required": true,
        "sensitive": true
      },
      {
        "key": "MS_CLIENT_SECRET",
        "label": "Azure App Client Secret",
        "description": "Client secret from Azure Portal App Registration",
        "required": true,
        "sensitive": true
      }
    ],
    "oauth": {
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "scopes": [
        "offline_access",
        "User.Read",
        "Calendars.Read",
        "Calendars.ReadWrite",
        "Mail.Read",
        "Contacts.Read",
        "Tasks.Read"
      ]
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "calendarId": {
        "type": "string",
        "description": "Specific calendar ID to operate on (optional, defaults to primary)"
      }
    }
  },
  "capabilities": ["tool"],
  "tags": ["calendar", "scheduling", "microsoft", "outlook", "mcp"],
  "popularity": 68
}
