{
  "id": "elevenlabs",
  "name": "ElevenLabs",
  "description": "AI voice generation, text-to-speech, voice cloning, sound effects, and audio processing via ElevenLabs MCP server",
  "version": "1.0.0",
  "category": "media",
  "icon": "volume-2",
  "website": "https://elevenlabs.io",
  "docs": "https://elevenlabs.io/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "ELEVENLABS_API_KEY",
        "label": "API Key",
        "description": "ElevenLabs API key from https://elevenlabs.io/app/settings/api-keys",
        "required": true,
        "sensitive": true,
        "placeholder": "sk_..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "voiceId": {
        "type": "string",
        "description": "Default voice ID for text-to-speech generation"
      },
      "model": {
        "type": "string",
        "enum": [
          "eleven_multilingual_v2",
          "eleven_turbo_v2_5",
          "eleven_turbo_v2",
          "eleven_monolingual_v1",
          "eleven_flash_v2_5",
          "eleven_flash_v2"
        ],
        "default": "eleven_turbo_v2_5",
        "description": "Default TTS model"
      },
      "outputMode": {
        "type": "string",
        "enum": ["files", "resources", "both"],
        "default": "files",
        "description": "How generated audio files are returned"
      }
    }
  },
  "capabilities": ["tool", "action"],
  "tags": ["media", "voice", "tts", "ai", "audio", "speech", "sound-effects"],
  "popularity": 78
}
