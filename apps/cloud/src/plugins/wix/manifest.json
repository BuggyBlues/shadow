{
  "id": "wix",
  "name": "Wix",
  "description": "Wix documentation, design system, SDK, and site API tools via the official Wix MCP server",
  "version": "1.0.0",
  "category": "media",
  "icon": "layout",
  "website": "https://wix.com",
  "docs": "https://dev.wix.com/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "WIX_API_KEY",
        "label": "API Key",
        "description": "Wix API key for site API access (optional for documentation tools)",
        "required": false,
        "sensitive": true
      },
      {
        "key": "WIX_SITE_ID",
        "label": "Site ID",
        "description": "Default Wix site ID for API operations",
        "required": false,
        "sensitive": false
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "tools": {
        "type": "string",
        "description": "Comma-separated standard tools to enable (WDS,REST,SDK,WIX_HEADLESS,BUILD_APPS,VELO,BUSINESS_SOLUTIONS)",
        "default": "WDS,REST,SDK"
      },
      "experimental": {
        "type": "string",
        "description": "Comma-separated experimental tools to enable (WIX_API,CLI_COMMAND,GET_TO_KNOW_WIX)"
      }
    }
  },
  "capabilities": ["tool", "data-source"],
  "tags": ["web", "cms", "website", "wix", "design-system"],
  "popularity": 52
}
