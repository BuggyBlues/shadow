{
  "id": "dify",
  "name": "Dify",
  "description": "AI workflow and application platform with Dify — orchestrate LLM apps, knowledge bases, and agent workflows",
  "version": "1.0.0",
  "category": "automation",
  "icon": "cpu",
  "website": "https://dify.ai",
  "docs": "https://docs.dify.ai",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "DIFY_API_KEY",
        "label": "API Key",
        "description": "Dify application API key from app settings",
        "required": true,
        "sensitive": true
      },
      {
        "key": "DIFY_BASE_URL",
        "label": "Base URL",
        "description": "Dify API base URL (cloud or self-hosted)",
        "required": true,
        "sensitive": false,
        "placeholder": "https://api.dify.ai/v1"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "appId": {
        "type": "string",
        "description": "Dify application ID to interact with"
      },
      "appType": {
        "type": "string",
        "enum": ["chat", "completion", "workflow", "agent"],
        "default": "workflow",
        "description": "Type of Dify application"
      }
    }
  },
  "capabilities": ["tool", "action"],
  "tags": ["automation", "ai", "workflow", "llm", "knowledge-base"],
  "popularity": 68
}
