{
  "id": "monday",
  "name": "monday.com",
  "description": "Work management with monday.com via official MCP server — manage boards, items, columns, groups, and updates through GraphQL API",
  "version": "1.0.0",
  "category": "project-management",
  "icon": "layout-grid",
  "website": "https://monday.com",
  "docs": "https://www.npmjs.com/package/@mondaydotcomorg/monday-api-mcp",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "MONDAY_API_TOKEN",
        "label": "API Token",
        "description": "monday.com API token from Admin → API",
        "required": true,
        "sensitive": true,
        "placeholder": "eyJhbGci..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "boardIds": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "description": "Specific board IDs to expose (all if empty)"
      }
    }
  },
  "capabilities": ["tool", "data-source", "action"],
  "tags": ["project-management", "work-management", "boards", "mcp"],
  "popularity": 65
}
