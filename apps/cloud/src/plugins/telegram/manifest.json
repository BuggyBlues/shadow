{
  "id": "telegram",
  "name": "Telegram",
  "description": "Connect agents to Telegram for bot messaging",
  "version": "1.0.0",
  "category": "communication",
  "icon": "send",
  "website": "https://telegram.org",
  "auth": {
    "type": "token",
    "fields": [
      {
        "key": "TELEGRAM_BOT_TOKEN",
        "label": "Bot Token",
        "required": true,
        "sensitive": true,
        "description": "Token from BotFather"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "allowedChats": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Chat IDs to respond in"
      },
      "polling": {
        "type": "boolean",
        "default": true,
        "description": "Use long polling"
      }
    }
  },
  "capabilities": ["channel", "webhook"],
  "tags": ["communication", "messaging", "bot"],
  "popularity": 82
}
