{
  "id": "atlassian",
  "name": "Atlassian",
  "description": "Jira and Confluence integration via MCP servers — manage issues, projects, sprints, wiki pages, and search across Atlassian Cloud",
  "version": "1.0.0",
  "category": "project-management",
  "icon": "trello",
  "website": "https://atlassian.com",
  "docs": "https://github.com/aashari/mcp-server-atlassian-jira",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "ATLASSIAN_API_TOKEN",
        "label": "API Token",
        "description": "Atlassian API token from https://id.atlassian.com/manage-profile/security/api-tokens",
        "required": true,
        "sensitive": true,
        "placeholder": "..."
      },
      {
        "key": "ATLASSIAN_USER_EMAIL",
        "label": "Email",
        "description": "Atlassian account email used for API authentication",
        "required": true,
        "sensitive": false,
        "placeholder": "user@company.com"
      },
      {
        "key": "ATLASSIAN_SITE_NAME",
        "label": "Site Name",
        "description": "Atlassian Cloud site name (the subdomain in your-company.atlassian.net)",
        "required": true,
        "sensitive": false,
        "placeholder": "mycompany"
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "enableJira": {
        "type": "boolean",
        "default": true,
        "description": "Enable Jira MCP server for issue/project management"
      },
      "enableConfluence": {
        "type": "boolean",
        "default": true,
        "description": "Enable Confluence MCP server for wiki/knowledge base access"
      }
    }
  },
  "capabilities": ["tool", "data-source", "action"],
  "tags": ["project-management", "jira", "confluence", "wiki", "issues", "mcp"],
  "popularity": 78
}
