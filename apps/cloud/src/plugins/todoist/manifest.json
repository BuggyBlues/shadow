{
  "id": "todoist",
  "name": "Todoist",
  "description": "Complete task and project management with Todoist via MCP server — create, update, complete tasks, manage projects, labels, and filters",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "check-circle",
  "website": "https://todoist.com",
  "docs": "https://www.npmjs.com/package/@greirson/mcp-todoist",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "TODOIST_API_TOKEN",
        "label": "Todoist API Token",
        "description": "API token from https://todoist.com/app/settings/integrations/developer",
        "required": true,
        "sensitive": true,
        "placeholder": "e.g. 0123456789abcdef..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "Default project ID to scope operations to"
      },
      "dryRun": {
        "type": "boolean",
        "default": false,
        "description": "Test operations without making real changes"
      }
    }
  },
  "capabilities": ["tool"],
  "tags": ["productivity", "tasks", "todo", "mcp"],
  "popularity": 65
}
