# E2E environment for shadow-cloud CLI tests
# Copy this to .env.e2e and fill in your values.
# .env.e2e is gitignored.

# Shadow server URL (docker-compose default)
E2E_ORIGIN=http://localhost:3000

# Optional: override E2E run ID (used for unique test resource names)
# E2E_RUN_ID=my-run-001

# Optional: pre-seeded owner credentials (seed script creates these)
# ADMIN_EMAIL=admin@shadowob.app
# ADMIN_PASSWORD=admin123456

# DeepSeek API key — used for agent probe E2E tests (test:e2e:probe)
# DeepSeek is OpenAI-API compatible; models: deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=sk-59915f72ef4d4c69ace3a9da04ab72ea

# Optional: ANTHROPIC settings for claude-runner tests
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: override K8s context
# KUBECONFIG_CONTEXT=rancher-desktop

# Optional: Pulumi backend override
# PULUMI_BACKEND_URL=file:///tmp/shadow-cloud-e2e-pulumi
