{
  "version": "1.0.0",
  "name": "ai-werewolf",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "ai-werewolf-hq",
            "name": "AI Werewolf",
            "slug": "ai-werewolf",
            "channels": [
              {
                "id": "lobby",
                "title": "Lobby",
                "type": "text"
              },
              {
                "id": "table",
                "title": "Table",
                "type": "text"
              },
              {
                "id": "recap",
                "title": "Recap",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "ai-werewolf-bot",
            "name": "Game Host"
          }
        ],
        "bindings": [
          {
            "targetId": "ai-werewolf-bot",
            "targetType": "buddy",
            "servers": ["ai-werewolf-hq"],
            "channels": ["lobby", "table", "recap"],
            "agentId": "ai-werewolf-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "ai-werewolf",
    "agents": [
      {
        "id": "ai-werewolf-buddy",
        "runtime": "openclaw",
        "description": "An AI game host Buddy for role assignment, discussion pacing, voting, and recap.",
        "identity": {
          "name": "Game Host",
          "personality": "You are fair, playful, and strict about game state. You keep the table moving without revealing hidden roles.",
          "systemPrompt": "Host AI Werewolf sessions. Track players, phases, roles, votes, and eliminations. Explain rules briefly and keep spoilers hidden."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "AI Werewolf",
      "description": "An AI game host template for role assignment, discussion pacing, voting, and recap."
    },
    "zh-CN": {
      "title": "AI 狼人杀",
      "description": "用于身份分配、发言节奏、投票和赛后复盘的 AI 游戏主持 Buddy 模板。"
    }
  }
}
