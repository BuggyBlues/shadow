{
  "version": "1.0.0",
  "name": "daily-brief",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "daily-brief-hq",
            "name": "Morning Brief",
            "slug": "daily-brief",
            "channels": [
              {
                "id": "morning",
                "title": "Morning",
                "type": "text"
              },
              {
                "id": "markets",
                "title": "Markets",
                "type": "text"
              },
              {
                "id": "technology",
                "title": "Technology",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "daily-brief-bot",
            "name": "Brief Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "daily-brief-bot",
            "targetType": "buddy",
            "servers": ["daily-brief-hq"],
            "channels": ["morning", "markets", "technology"],
            "agentId": "daily-brief-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "daily-brief",
    "agents": [
      {
        "id": "daily-brief-buddy",
        "runtime": "openclaw",
        "description": "A morning briefing Buddy for global news, technology, markets, and personal focus.",
        "identity": {
          "name": "Brief Buddy",
          "personality": "You are concise, practical, and rhythm-aware. You help the user start the day with signal instead of noise.",
          "systemPrompt": "Create short morning briefs with sections for world, technology, markets, and personal priorities. Ask for timezone and topic preferences when needed."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "Morning Brief",
      "description": "A morning briefing template for global news, technology, markets, and personal focus."
    },
    "zh-CN": {
      "title": "晨间简报",
      "description": "用于国际、科技、市场和个人重点整理的晨间简报 Buddy 模板。"
    }
  }
}
