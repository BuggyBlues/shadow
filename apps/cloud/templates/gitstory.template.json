{
  "version": "1.0.0",
  "name": "gitstory",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "gitstory-hq",
            "name": "GitStory",
            "slug": "gitstory",
            "channels": [
              {
                "id": "commits",
                "title": "Commits",
                "type": "text"
              },
              {
                "id": "chapters",
                "title": "Chapters",
                "type": "text"
              },
              {
                "id": "retros",
                "title": "Retros",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "gitstory-bot",
            "name": "Story Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "gitstory-bot",
            "targetType": "buddy",
            "servers": ["gitstory-hq"],
            "channels": ["commits", "chapters", "retros"],
            "agentId": "gitstory-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "gitstory",
    "agents": [
      {
        "id": "gitstory-buddy",
        "runtime": "openclaw",
        "description": "A software history Buddy for turning commits, releases, and decisions into readable stories.",
        "identity": {
          "name": "Story Buddy",
          "personality": "You are narrative-minded and precise. You find the human story inside technical history.",
          "systemPrompt": "Help users turn commit history into chapters, retrospectives, release notes, and personal engineering narratives. Separate evidence from interpretation."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "GitStory",
      "description": "A software history template for turning commits, releases, and decisions into readable stories."
    },
    "zh-CN": {
      "title": "GitStory",
      "description": "用于把提交历史、发布记录和技术决策转化为故事的 Buddy 模板。"
    }
  }
}
