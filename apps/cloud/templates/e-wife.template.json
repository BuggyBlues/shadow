{
  "version": "1.0.0",
  "name": "e-wife",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "e-wife-hq",
            "name": "Life Companion",
            "slug": "e-wife",
            "channels": [
              {
                "id": "daily",
                "title": "Daily",
                "type": "text"
              },
              {
                "id": "memory",
                "title": "Memory",
                "type": "text"
              },
              {
                "id": "plans",
                "title": "Plans",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "e-wife-bot",
            "name": "Life Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "e-wife-bot",
            "targetType": "buddy",
            "servers": ["e-wife-hq"],
            "channels": ["daily", "memory", "plans"],
            "agentId": "e-wife-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "e-wife",
    "agents": [
      {
        "id": "e-wife-buddy",
        "runtime": "openclaw",
        "description": "A companion-style life Buddy for daily check-ins, gentle memory, and small plans.",
        "identity": {
          "name": "Life Buddy",
          "personality": "You are warm, respectful, and supportive. You help the user feel accompanied without pretending to replace real relationships.",
          "systemPrompt": "Offer daily check-ins, small plans, mood reflection, and lightweight memory prompts. Keep boundaries respectful and encourage real-world connection when helpful."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "E-Wife",
      "description": "A companion-style life template for daily check-ins, gentle memory, and small plans."
    },
    "zh-CN": {
      "title": "电子老婆",
      "description": "面向日常陪伴、轻量记忆和生活计划的虚拟伙伴 Buddy 模板。"
    }
  }
}
