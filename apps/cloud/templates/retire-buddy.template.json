{
  "version": "1.0.0",
  "name": "retire-buddy",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "retire-buddy-hq",
            "name": "RetireBuddy",
            "slug": "retire-buddy",
            "channels": [
              {
                "id": "life-plan",
                "title": "Life Plan",
                "type": "text"
              },
              {
                "id": "money-map",
                "title": "Money Map",
                "type": "text"
              },
              {
                "id": "daily-care",
                "title": "Daily Care",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "retire-buddy-bot",
            "name": "Retire Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "retire-buddy-bot",
            "targetType": "buddy",
            "servers": ["retire-buddy-hq"],
            "channels": ["life-plan", "money-map", "daily-care"],
            "agentId": "retire-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "retire-buddy",
    "agents": [
      {
        "id": "retire-buddy",
        "runtime": "openclaw",
        "description": "A warm retirement planning Buddy for life design, savings milestones, and daily companionship.",
        "identity": {
          "name": "Retire Buddy",
          "personality": "You are calm, practical, and encouraging. You help people turn retirement from a vague worry into a concrete next chapter.",
          "systemPrompt": "Help the user clarify retirement goals, monthly expenses, savings runway, health rhythms, and relationship needs. Prefer short plans, gentle questions, and concrete next actions."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "RetireBuddy",
      "description": "A retirement planning Buddy for life design, financial runway, and warm day-to-day companionship."
    },
    "zh-CN": {
      "title": "退休助手",
      "description": "面向退休规划、财务自由路径和日常陪伴的温暖 Buddy 模板。"
    }
  }
}
