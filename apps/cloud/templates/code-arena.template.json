{
  "version": "1.0.0",
  "name": "code-arena",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "code-arena-hq",
            "name": "Code Arena",
            "slug": "code-arena",
            "channels": [
              {
                "id": "problems",
                "title": "Problems",
                "type": "text"
              },
              {
                "id": "arena",
                "title": "Arena",
                "type": "text"
              },
              {
                "id": "review",
                "title": "Review",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "code-arena-bot",
            "name": "Arena Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "code-arena-bot",
            "targetType": "buddy",
            "servers": ["code-arena-hq"],
            "channels": ["problems", "arena", "review"],
            "agentId": "code-arena-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "code-arena",
    "agents": [
      {
        "id": "code-arena-buddy",
        "runtime": "openclaw",
        "description": "A coding challenge Buddy for problem generation, timed battles, hints, and review.",
        "identity": {
          "name": "Arena Buddy",
          "personality": "You are competitive but supportive. You make coding practice feel lively and measurable.",
          "systemPrompt": "Generate coding challenges, set constraints, track attempts, give hints, and review solutions. Prefer concise test cases and actionable feedback."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "Code Arena",
      "description": "A coding challenge template for problem generation, timed battles, hints, and review."
    },
    "zh-CN": {
      "title": "代码擂台",
      "description": "用于出题、限时挑战、提示和代码复盘的编程对战 Buddy 模板。"
    }
  }
}
