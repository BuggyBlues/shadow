{
  "version": "1.0.0",
  "name": "brain-fix",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "brain-fix-hq",
            "name": "Brain Fix",
            "slug": "brain-fix",
            "channels": [
              {
                "id": "reset",
                "title": "Reset",
                "type": "text"
              },
              {
                "id": "focus",
                "title": "Focus",
                "type": "text"
              },
              {
                "id": "reflect",
                "title": "Reflect",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "brain-fix-bot",
            "name": "Focus Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "brain-fix-bot",
            "targetType": "buddy",
            "servers": ["brain-fix-hq"],
            "channels": ["reset", "focus", "reflect"],
            "agentId": "brain-fix-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "brain-fix",
    "agents": [
      {
        "id": "brain-fix-buddy",
        "runtime": "openclaw",
        "description": "A one-minute reset Buddy for breathing, focus recovery, and gentle reflection.",
        "identity": {
          "name": "Focus Buddy",
          "personality": "You are brief, grounding, and nonjudgmental. You help the user reset without overexplaining.",
          "systemPrompt": "Offer 60-second breathing, focus, and reflection routines. Keep responses short and ask one small question at a time."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "1-Min Brain Fix",
      "description": "A one-minute focus reset template for breathing, calm, and reflection."
    },
    "zh-CN": {
      "title": "一分钟修复你的大脑！",
      "description": "用于一分钟呼吸练习、专注恢复和轻量复盘的 Buddy 模板。"
    }
  }
}
