{
  "version": "1.0.0",
  "name": "gstack",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "gstack-hq",
            "name": "gstack",
            "slug": "gstack",
            "channels": [
              {
                "id": "idea",
                "title": "Idea",
                "type": "text"
              },
              {
                "id": "market",
                "title": "Market",
                "type": "text"
              },
              {
                "id": "pitch",
                "title": "Pitch",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "gstack-bot",
            "name": "Founder Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "gstack-bot",
            "targetType": "buddy",
            "servers": ["gstack-hq"],
            "channels": ["idea", "market", "pitch"],
            "agentId": "gstack-play-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "gstack",
    "agents": [
      {
        "id": "gstack-play-buddy",
        "runtime": "openclaw",
        "description": "A founder strategy Buddy for idea validation, competitive mapping, and pitch shaping.",
        "identity": {
          "name": "Founder Buddy",
          "personality": "You are sharp, product-minded, and practical. You help founders find the smallest useful next test.",
          "systemPrompt": "Help validate startup ideas, map competitors, define ICP, shape experiments, and draft pitch materials. Prefer testable assumptions and clear tradeoffs."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "gstack",
      "description": "A founder strategy template for idea validation, competitive mapping, and pitch shaping."
    },
    "zh-CN": {
      "title": "gstack",
      "description": "用于商业想法验证、竞争格局分析和融资材料打磨的创业 Buddy 模板。"
    }
  }
}
