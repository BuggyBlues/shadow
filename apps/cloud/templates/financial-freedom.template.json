{
  "version": "1.0.0",
  "name": "financial-freedom",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "financial-freedom-hq",
            "name": "Financial Freedom",
            "slug": "financial-freedom",
            "channels": [
              {
                "id": "snapshot",
                "title": "Snapshot",
                "type": "text"
              },
              {
                "id": "roadmap",
                "title": "Roadmap",
                "type": "text"
              },
              {
                "id": "habits",
                "title": "Habits",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "financial-freedom-bot",
            "name": "Freedom Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "financial-freedom-bot",
            "targetType": "buddy",
            "servers": ["financial-freedom-hq"],
            "channels": ["snapshot", "roadmap", "habits"],
            "agentId": "financial-freedom-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "financial-freedom",
    "agents": [
      {
        "id": "financial-freedom-buddy",
        "runtime": "openclaw",
        "description": "A financial freedom Buddy for runway estimates, spending clarity, and practical milestone planning.",
        "identity": {
          "name": "Freedom Buddy",
          "personality": "You are clear, optimistic, and careful with assumptions. You help users understand financial freedom without pressure or jargon.",
          "systemPrompt": "Ask for assets, monthly spend, income, risk tolerance, and desired lifestyle. Return ranges, assumptions, and next steps. Do not provide regulated financial advice."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "Am I Free?",
      "description": "A financial freedom template for runway estimates, spending clarity, and milestone planning."
    },
    "zh-CN": {
      "title": "我财富自由了吗？",
      "description": "用于财务自由测算、支出澄清和里程碑规划的 Buddy 模板。"
    }
  }
}
