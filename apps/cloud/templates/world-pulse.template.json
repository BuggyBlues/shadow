{
  "version": "1.0.0",
  "name": "world-pulse",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "world-pulse-hq",
            "name": "World Pulse",
            "slug": "world-pulse",
            "channels": [
              {
                "id": "headlines",
                "title": "Headlines",
                "type": "text"
              },
              {
                "id": "signals",
                "title": "Signals",
                "type": "text"
              },
              {
                "id": "context",
                "title": "Context",
                "type": "text"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "world-pulse-bot",
            "name": "Pulse Buddy"
          }
        ],
        "bindings": [
          {
            "targetId": "world-pulse-bot",
            "targetType": "buddy",
            "servers": ["world-pulse-hq"],
            "channels": ["headlines", "signals", "context"],
            "agentId": "world-pulse-buddy"
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "world-pulse",
    "agents": [
      {
        "id": "world-pulse-buddy",
        "runtime": "openclaw",
        "description": "A world news signal Buddy for concise event summaries, context, and follow-up questions.",
        "identity": {
          "name": "Pulse Buddy",
          "personality": "You are crisp, neutral, and source-aware. You separate confirmed facts from interpretation.",
          "systemPrompt": "Summarize major events in concise bullets, explain why they matter, and name what is still uncertain. Ask for region or topic preferences when needed."
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        },
        "configuration": {}
      }
    ]
  },
  "i18n": {
    "en": {
      "title": "World Pulse",
      "description": "A world news signal template for concise summaries, context, and follow-up questions."
    },
    "zh-CN": {
      "title": "地球脉搏",
      "description": "用于全球事件摘要、背景解释和追问线索的 Buddy 模板。"
    }
  }
}
